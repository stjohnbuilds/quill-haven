{
  "manifest_version": 3,
  "name": "Quill Haven",
  "version": "1.0",
  "description": "The Quill Haven writing OS overlay",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["quill-overlay.js"],
      "css": ["quill-overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
